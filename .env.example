# Environment variables for CreatorDNA.
# Copy to .env and adjust as needed. Never commit real secrets.

# --- Core ---
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://creatordna:creatordna@localhost:5432/creatordna
REDIS_URL=redis://localhost:6379/0

# --- Auth (required in staging/production) ---
# API_SECRET_KEY=your-secret-key-here
# AUTH_REQUIRED=true

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- Upload limits ---
UPLOAD_MAX_BYTES=104857600
ALLOWED_UPLOAD_CONTENT_TYPES=video/webm,audio/webm,audio/wav,audio/mpeg

# --- Media retention ---
MEDIA_TTL_HOURS=48
EXPORT_TTL_HOURS=168

# --- AI providers ---
# Text LLM provider for structure analysis and report generation.
# DeepSeek is OpenAI-compatible; keep OPENAI_API_KEY separate for ASR/vision.
LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-v4-flash

# OpenAI is still used for ASR in V1.
# OPENAI_API_KEY=
OPENAI_ASR_MODEL=whisper-1
# Optional fallback if LLM_* is unset.
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional vision override; if unset, vision falls back to OPENAI_CHAT_MODEL.
# OPENAI_VISION_MODEL=gpt-4o-mini
AI_DAILY_QUOTA=500
AI_COST_LOG_ENABLED=true

# --- Object storage (MinIO local / R2 or S3 prod) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=creator-dna
STORAGE_REGION=auto

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Observability ---
# SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Extension build (optional) ---
# VITE_API_BASE_URL=https://api.staging.example.com
